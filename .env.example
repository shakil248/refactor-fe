# Example environment configuration for frontend
# Copy this file to .env and update the values

# Backend API URL
# For local development: http://localhost:8080
# For production: https://your-api-domain.com
REACT_APP_API_URL=https://refactor-production-0fd4.up.railway.app

# Optional: Enable debug mode
# REACT_APP_DEBUG=true

# ---- Google AdSense ----
# Publisher ID from your AdSense account. Leave empty (or REACT_APP_ADS_ENABLED=false)
# to disable ads entirely. Ads never render in NODE_ENV=development.
REACT_APP_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
REACT_APP_ADS_ENABLED=true

# Per-placement slot IDs (configure each ad unit in AdSense and paste its slot ID).
REACT_APP_ADSENSE_SLOT_DASHBOARD=1234567890

